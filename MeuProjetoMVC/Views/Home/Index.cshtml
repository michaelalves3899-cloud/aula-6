@{
    ViewData["Title"] = "Exercícios de Front-End";
}

<div class="container mt-4">
    <div class="card p-4 mb-5 shadow-sm">
        <h2 class="text-primary">Validação Interativa de Formulário</h2>
        <form id="meuFormulario" class="mt-3">
            <div class="mb-3">
                <label for="nome" class="form-label">Nome:</label>
                <input type="text" id="nome" class="form-control">
            </div>
            <div class="mb-3">
                <label for="email" class="form-label">Email:</label>
                <input type="text" id="email" class="form-control">
            </div>
            <div class="mb-3">
                <label for="idade" class="form-label">Idade:</label>
                <input type="number" id="idade" class="form-control">
            </div>
            <button type="submit" class="btn btn-primary">Enviar Formulário</button>
        </form>
        <p id="erro" style="color: red; margin-top: 15px; font-weight: bold;"></p>
    </div>

    <hr>

    <div class="card p-4 text-center shadow-sm mt-5">
        <h2 class="text-success">Contador Interativo</h2>
        <h1 id="numero" class="display-1 my-4" style="transition: color 0.3s;">0</h1>
        <div>
            <button id="btnDecrementar" class="btn btn-danger me-2">Decrementar</button>
            <button id="btnZerar" class="btn btn-secondary me-2">Zerar</button>
            <button id="btnIncrementar" class="btn btn-success">Incrementar</button>
        </div>
    </div>
</div>

<script src="~/js/validacao.js"></script>
<script src="~/js/contador.js"></script>